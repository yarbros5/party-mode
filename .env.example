# Copy this file to .env and fill in your values.
# Never commit .env to GitHub — it contains your secret tokens.

# Your LIFX Cloud API token.
# Get one at: https://cloud.lifx.com/settings
LIFX_API_TOKEN=your_lifx_api_token_here

# Your Anthropic API key (used for Claude AI vibe interpretation).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
